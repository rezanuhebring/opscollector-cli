# OpsCollector Sync Server — env template (copy to .env and edit)
# This file is safe to commit; contains NO real secrets.

# Host port the API publishes on (internal/LAN only). Avoid 80/443/8000 if taken.
API_PORT=9000
# Bind address: 127.0.0.1 = localhost only (safe for internal/LAN). Use 0.0.0.0 ONLY behind a VPN/firewall.
API_HOST=127.0.0.1

# PostgreSQL (internal network only; not published to host)
POSTGRES_DB=opscollector
POSTGRES_USER=ops
POSTGRES_PASSWORD=change-me-in-production

# Server config
SECRET_KEY=changeme-internal
SERVER_SCHEMA_VERSION=1
ALLOWED_DRIFT=0

# Internal DB URL used by the api container (db service name, not localhost)
DATABASE_URL=postgresql+psycopg2://ops:change-me-in-production@db:5432/opscollector
