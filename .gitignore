# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# App data (keep structure, ignore contents)
database/*.db
database/*.db-journal
evidence/**
export/**
backup/**
logs/**
!evidence/.gitkeep
!export/.gitkeep
!backup/.gitkeep
!logs/.gitkeep

# Secrets / credentials (never commit)
.env
.env.*
*.env
*.pem
*.key
secrets.json
credentials.json
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.pfx
*.p12

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Test caches
.pytest_cache/
*.cover
